# ---------------------------------------------------------------------------
# vtex.env — Environment variables for local development
#
# This file is read by `@faststore/cli` (`dev` and `generate-i18n` commands)
# and the parsed values are injected into `process.env` when running locally.
#
# ⚠️  PRODUCTION: Do NOT rely on this file in production. In production,
#     configure these variables directly in the FastStore WebOps Settings page.
#     See: https://developers.vtex.com/docs/guides/faststore
#
# ⚠️  SECRETS: Never commit secret values (App Keys, App Tokens, etc.) to this
#     file. For local secrets, copy `.env.example` to `.env.local` (gitignored)
#     and fill in your credentials there.
# ---------------------------------------------------------------------------

# --- Next.js -----------------------------------------------------------------

## Disables Next.js telemetry data collection.
## Docs: https://nextjs.org/telemetry
NEXT_TELEMETRY_DISABLED=1

# --- FastStore WebOps --------------------------------------------------------

## Enables re-using `node_modules` from previous runs for faster builds.
USE_BUILD_CACHE=true

## Enables Incremental Static Builds (ISB) on WebOps, so pages built in
## previous deploys are reused when their content has not changed.
## Docs: https://www.faststore.dev/releases/2022/05/19/webops
USE_STALE_CACHE=true

## Production hostname your users will access the website through.
## Used by SEO/SSR utilities (canonical URLs, sitemap, robots.txt, etc.).
SITE_HOST=demo.faststore.dev


# Optional. Disables nextjs telemetry
NEXT_TELEMETRY_DISABLED=true

# Optional. Possible values are development | production. Node environment runtime.
NODE_ENV=""

# Optional. Disables the injection of third party scripts declared customizations. If not present default is false.
DISABLE_3P_SCRIPTS=false

# Optional.
BASE_SITE_URL=''

# OPTIONAL. Way to mock CMS rewsponse in order to test specific response.
CMS_DATA=''

# OPTIONAL. Used to make @faststore/cli print log messages on terminal
DISCOVERY_DEBUG=''

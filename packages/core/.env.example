# shellcheck shell=bash
# shellcheck disable=SC2034
# ---------------------------------------------------------------------------
# .env.example — Template for local environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values for
# local development. Never commit real secrets to the repository.
#
#   cp .env.example .env.local
#
# In production, configure these variables in the FastStore WebOps Settings
# page instead of relying on env files.
# ---------------------------------------------------------------------------

# --- Next.js -----------------------------------------------------------------

## Disables Next.js telemetry data collection. (`1` to disable, unset to enable)
## Docs: https://nextjs.org/telemetry
NEXT_TELEMETRY_DISABLED=1

# --- FastStore WebOps --------------------------------------------------------

## Re-use `node_modules` from previous runs to speed up builds.
USE_BUILD_CACHE=true

## Enable Incremental Static Builds (ISB) — reuses pages from previous builds
## when their content has not changed.
## Docs: https://www.faststore.dev/releases/2022/05/19/webops
USE_STALE_CACHE=true

## Production hostname your users will access the website through.
## Used by SEO/SSR utilities (canonical URLs, sitemap, robots.txt, etc.).
SITE_HOST=www.example.com

# --- VTEX API credentials ----------------------------------------------------
#
# Server-to-server authentication for VTEX APIs. Generate an App Key / App
# Token at: https://help.vtex.com/en/tutorial/creating-appkeys-and-apptokens
#
# Required by:
#   - `@faststore/api` (getWithAppKeyAndToken) for authenticated platform calls
#   - `@faststore/cli` `generate-i18n` command (alongside VTEX_ACCOUNT)
#
# In production, set these in WebOps Settings — never commit real values.

## VTEX App Key (public identifier of the application).
FS_DISCOVERY_APP_KEY=vtexappkey-mystore-XXXXXX

## VTEX App Token (secret; treat like a password).
FS_DISCOVERY_APP_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

## (Optional) VTEX account name, required by the `generate-i18n` CLI command.
## Uncomment and set when running localization commands locally.
# VTEX_ACCOUNT=mystore

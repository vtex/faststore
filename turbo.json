{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "OCLIF_COMPILATION",
    "NODE_ENV",
    "DISABLE_3P_SCRIPTS",
    "CMS_DATA",
    "DISCOVERY_DEBUG"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["BASE_SITE_URL"],
      "outputs": ["dist/**"]
    },
    "preinstall": {
      "dependsOn": ["^preinstall"],
      "env": ["CA_TOKEN"]
    },
    "generate": {},
    "@faststore/api#build": {
      "dependsOn": ["generate", "^build"],
      "env": ["BASE_SITE_URL"],
      "outputs": ["dist/**"]
    },
    "@faststore/api#generate": {
      "outputs": ["src/__generated__/**"]
    },
    "@faststore/core#generate": {
      "dependsOn": ["^generate", "@faststore/cli#build"],
      "outputs": ["@generated/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["coverage/**"]
    },
    "lint": {},
    "serve": {},
    "start": {
      "outputs": ["dist/**"]
    },
    "size": {},
    "dev": {
      "cache": false
    },
    "dev:server": {
      "cache": false
    },
    "@faststore/api#dev:graphql": {
      "outputs": ["dist/**"]
    }
  }
}
